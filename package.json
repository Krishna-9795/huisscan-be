{
  "name": "huiscan-be",
  "version": "1.0.0",
  "description": "Fastify backend API for a real estate/property report app.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "keywords": [
    "fastify",
    "typescript",
    "prisma",
    "postgresql"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/sensible": "^6.0.3",
    "@prisma/client": "^6.10.1",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.3",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^24.0.4",
    "prisma": "^6.10.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
