DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
JWT_SECRET="change-me"
PORT=4000
API_PREFIX="/api/v1"
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
PUBLIC_APP_URL="http://localhost:3000"
# Backend origin only. Do not include API_PREFIX here.
# Localhost is OK for browser returns; Mollie webhooks are only sent for public HTTPS URLs.
PUBLIC_API_URL="https://your-public-backend-url.example.com"

# Kadaster dashboard cache and live-call controls.
# Default behavior is cache-only, so no paid Kadaster calls happen.
REDIS_URL="redis://127.0.0.1:6379"
# Keep this prefix aligned with the old huisscan-1 prefix while migrating.
KADASTER_CACHE_PREFIX="huisscan:kadaster-dashboard"
KADASTER_DASHBOARD_CACHE_DIR="../huisscan-1/.cache/kadaster-dashboard"
KADASTER_LIVE_CALLS_ENABLED=false
# one = only first address below, list = semicolon-separated allowlist, all = any address.
KADASTER_ALLOWED_ADDRESS_MODE=one
KADASTER_ALLOWED_ADDRESSES="Muiderbos 1, 2134 SM, Hoofddorp"

MOLLIE_TEST_API_KEY="test_xxx"
